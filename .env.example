# 서버 전용 API 키 — 실제 값은 .env.local(로컬) / Vercel 환경변수(배포)에만 둔다.
# 클라이언트(NEXT_PUBLIC_*)로 절대 노출 금지.

GEMINI_API_KEY=
TYPECAST_API_KEY=
TYPECAST_DEFAULT_VOICE_ID=

# 선택: Gemini 모델 오버라이드 (미설정 시 gemini-3.1-flash-lite — 신규 사용자 가용·저가 Lite)
# GEMINI_MODEL=
# 선택: 404/429/503 시 재시도할 대체 모델 (기본 gemini-3.5-flash)
# GEMINI_FALLBACK_MODEL=
